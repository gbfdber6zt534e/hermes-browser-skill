{
  "name": "perplexity-auth2api",
  "version": "1.0.0",
  "description": "Perplexity browser session → OpenAI-compatible API bridge",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "login": "node dist/index.js --login",
    "login:manual": "node dist/index.js --login --manual",
    "login:headless": "node dist/index.js --login --headless"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "express": "^4.19.0",
    "puppeteer-core": "^22.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0"
  }
}
